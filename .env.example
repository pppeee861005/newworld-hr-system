# ============================================================================
# 環境配置範本
# ============================================================================
# 複製此文件為 .env，填入實際的值

# Google Workspace 配置
GOOGLE_PROJECT_ID=your-google-project-id
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_WORKSPACE_DOMAIN=your-company.com

# Google Forms 配置
GOOGLE_FORMS_ID=your-form-id-for-leave-requests

# Google Sheets 配置
GOOGLE_SHEET_ID=your-sheet-id-for-tracking
GOOGLE_SHEET_TAB_NAME=請假審批記錄

# Claude API 配置
CLAUDE_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-opus-4-1  # 或 claude-sonnet-4, claude-haiku-4

# NotebookLM 配置（可選）
NOTEBOOKLM_API_KEY=your-notebooklm-api-key
NOTEBOOKLM_KNOWLEDGE_BASE_ID=your-kb-id

# 應用程序配置
NODE_ENV=development
LOG_LEVEL=info
DEBUG=false

# Workflow 配置
WORKFLOW_TIMEOUT_MS=300000  # 5 分鐘超時
WORKFLOW_MAX_RETRIES=3
WORKFLOW_ENABLE_MONITORING=true

# 部署配置
DEPLOYMENT_ENV=local  # local, staging, production
