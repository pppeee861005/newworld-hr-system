# ===================================
# 環境變量與機密文件
# ===================================
.env
.env.local
.env.*.local
*.key
*.pem
credentials.json
service-account.json
secrets/

# ===================================
# Node.js 依賴
# ===================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ===================================
# 構建產物
# ===================================
dist/
build/
out/
*.js.map
*.d.ts.map

# ===================================
